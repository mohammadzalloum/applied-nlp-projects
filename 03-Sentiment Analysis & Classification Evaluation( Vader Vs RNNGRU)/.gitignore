# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/
venv/
ENV/

# VS Code / IDE
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# System files
.DS_Store
Thumbs.db

# Local/generated CUDA helper
ptxas

# Temporary / duplicate files
gitignore.text
main2.py

# Optional: ignore old notebook if it was only for experiments
main.ipynb

# Word documents / assignment notes
*.docx

# Keep outputs folder structure, but ignore everything by default
outputs/*
!outputs/vader_analysis/
!outputs/recurrent_models/
!outputs/comparative_analysis/

# Important VADER outputs
!outputs/vader_analysis/vader_metrics.json
!outputs/vader_analysis/vader_classification_report.txt
!outputs/vader_analysis/vader_confusion_matrix.png

# Important recurrent model outputs
!outputs/recurrent_models/rnn_lstm_gru_comparison.csv
!outputs/recurrent_models/recurrent_model_config.json
!outputs/recurrent_models/*_training_history.csv
!outputs/recurrent_models/*_classification_report.txt
!outputs/recurrent_models/*_confusion_matrix.png
!outputs/recurrent_models/*_accuracy_curve.png
!outputs/recurrent_models/*_loss_curve.png

# Important comparative analysis outputs
!outputs/comparative_analysis/final_performance_summary.csv
!outputs/comparative_analysis/method_comparison_table.csv
!outputs/comparative_analysis/critical_analysis_report.md

# Large generated prediction/error files
outputs/**/vader_predictions.csv
outputs/**/vader_errors.csv
outputs/**/*_test_predictions.csv

# Logs
*.log

hw.docx